# Default: treat any text-like file as text and store it with LF
# line endings in the repo. Cross-platform clones get the same
# bytes regardless of host OS conventions. Pairs with
# `.editorconfig`'s `end_of_line = lf` for editor-side enforcement.
* text=auto eol=lf

# Binary asset types — never normalise these.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.avif   binary
*.ico    binary
*.zip    binary
*.mdx    binary
*.mdz    binary
*.epub   binary
*.pdf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.glb    binary
*.gltf   binary

# Per-language overrides — be explicit so the .gitattributes
# defaults don't silently change in some future Git release.
*.ts     text eol=lf diff=typescript
*.tsx    text eol=lf diff=typescript
*.js     text eol=lf diff=javascript
*.py     text eol=lf diff=python
*.rs     text eol=lf diff=rust
*.md     text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.html   text eol=lf diff=html
*.css    text eol=lf diff=css

# Generated lockfiles — keep diffable but mark as generated so
# review tools collapse them.
package-lock.json   text eol=lf linguist-generated=true
Cargo.lock          text eol=lf linguist-generated=true
