# Dependencies
node_modules/

# Build outputs
dist/
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Claude Code local files (keep settings.json)
.claude/*.local.md
.claude/*.local.json

# Playwright MCP artifacts
.playwright-mcp/

# Playwright artifacts (Phase 2.3a.7 editor-desktop e2e)
editor-desktop/test-results/
editor-desktop/playwright-report/
editor-desktop/playwright/.cache/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
# hypothesis (property-based testing) cache — relocated to tests/property/
# by `HYPOTHESIS_STORAGE_DIRECTORY` in test_parser_properties.py; the
# explicit ignore here guards against the env-var being missed.
.hypothesis/

# TypeScript
*.js.map
*.d.ts

# Temporary files
*.tmp
*.temp
tmpclaude-ffc2-cwd
*.db-wal
*.db-shm

# Claude Code Memory MCP database (session-local working state)
memory.db
memory.db-*

# Dropbox selective sync marker (local-only)
.dropboxignore

# Local generator output (CI regenerates; not source of truth)
implementations/python/example-document.mdx
implementations/python/example-extracted/

# TypeScript test infrastructure
implementations/typescript/node_modules/
implementations/typescript/package-lock.json

# Browser-extension build output (CI regenerates; not source of truth)
mdz-viewer-extension-*.zip
mdz-viewer-extension-*.xpi
