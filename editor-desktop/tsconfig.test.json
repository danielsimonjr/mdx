{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "comment": "tsconfig.test.json excludes the Electron-specific main.ts + preload.ts files. They depend on `import 'electron'` which is in optionalDependencies and may not be installed in CI. Build-time + dev-time tooling (npm run build, npm run dev) uses tsconfig.main.json which DOES include them and DOES require Electron present.",
  "include": [
    "src/main/archive-io.ts",
    "src/main/ipynb-import.ts",
    "src/main/variant-encoder.ts",
    "src/preload/types.ts",
    "src/renderer/index.ts",
    "src/renderer/editor-pane.ts",
    "src/renderer/editor-pane-helpers.ts",
    "src/renderer/asset-store.ts",
    "src/renderer/directive-insert.ts",
    "src/renderer/directive-pickers.ts",
    "src/renderer/directive-modal.ts",
    "src/renderer/accessibility-checker.ts",
    "src/renderer/block-diff.ts",
    "src/renderer/annotations.ts",
    "src/renderer/locales.ts",
    "src/renderer/variant-planner.ts",
    "src/renderer/python-kernel.ts",
    "src/renderer/variant-flow.ts",
    "src/renderer/cell-runner.ts",
    "src/renderer/diff-render.ts",
    "src/renderer/annotations-render.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "src/main/main.ts",
    "src/preload/preload.ts"
  ]
}
