{
  "name": "tree-sitter-mdz",
  "version": "0.1.0-alpha",
  "description": "Tree-sitter grammar for MDZ directive syntax. Alpha — scaffold only; see spec/grammar/ for the normative grammar this will track.",
  "main": "bindings/node",
  "keywords": ["parser", "incremental", "tree-sitter", "mdz"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielsimonjr/mdx"
  },
  "dependencies": {
    "node-addon-api": "^7.0.0",
    "node-gyp-build": "^4.6.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.mdz",
      "file-types": ["mdz", "mdx"],
      "injection-regex": "^(mdz|mdx)$"
    }
  ]
}
