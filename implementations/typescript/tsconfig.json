{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "types": ["node"],
    "lib": ["es2020", "dom"],
    "noEmit": true
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}
